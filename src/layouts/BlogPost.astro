---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = Omit<CollectionEntry<'tech'>['data'], 'pubDate' | 'updatedDate'> & {
	pubDate?: Date;
	updatedDate?: Date;
};

const { title, subtitle, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: var(--content-width);
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.2em 0;
			}
			.subtitle {
				margin: 0 0 1em 0;
				font-size: 1.2em;
				color: rgb(var(--gray));
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<script>
		// Wrap heading text in anchor links so each heading is a copyable permalink
		document.querySelectorAll<HTMLElement>('.prose h1[id], .prose h2[id], .prose h3[id], .prose h4[id], .prose h5[id], .prose h6[id]').forEach((heading) => {
			const a = document.createElement('a');
			a.href = '#' + heading.id;
			a.className = 'heading-anchor';
			while (heading.firstChild) a.appendChild(heading.firstChild);
			heading.appendChild(a);
		});

		// Open external links in a new tab; leave #hash and same-origin links alone
		document.querySelectorAll<HTMLAnchorElement>('.prose a[href]').forEach((a) => {
			const href = a.getAttribute('href')!;
			if (!href.startsWith('#') && !href.startsWith('/')) {
				a.target = '_blank';
				a.rel = 'noopener noreferrer';
			}
		});

		const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
		const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;

		document.querySelectorAll('pre').forEach((pre) => {
			if (pre.closest('.twoslash-popup-container')) return;
			const btn = document.createElement('button');
			btn.className = pre.closest('.compare-before, .compare-after') ? 'copy-btn copy-btn--small' : 'copy-btn';
			btn.innerHTML = copyIcon;
			btn.setAttribute('aria-label', 'Copy code');
			btn.addEventListener('click', () => {
				const code = pre.dataset.fullSource ?? (() => {
					const codeEl = pre.querySelector('code')?.cloneNode(true) as Element | undefined;
					codeEl?.querySelectorAll('[class*="twoslash-popup"], .twoslash-error-box, .twoslash-error-line').forEach(el => el.remove());
					return [...(codeEl?.querySelectorAll('.line') ?? [])].map(l => l.textContent).join('\n');
				})();
				navigator.clipboard.writeText(code).then(() => {
					btn.innerHTML = checkIcon;
					setTimeout(() => (btn.innerHTML = copyIcon), 2000);
				});
			});
			pre.style.position = 'relative';
			pre.appendChild(btn);
		});

		document.querySelectorAll<HTMLElement>('.twoslash-query-persisted').forEach((span) => {
			const popup = span.querySelector('.twoslash-popup-container');
			const line = span.closest<HTMLElement>('.line');
			if (!popup || !line) return;
			const popupR = popup.getBoundingClientRect();
			const lineR = line.getBoundingClientRect();
			const existingPad = parseFloat(getComputedStyle(line).paddingBottom) || 0;
			const contentH = lineR.height - existingPad;
			const needed = popupR.bottom - lineR.top - contentH + 16;
			if (needed > 0) line.style.paddingBottom = needed + 'px';
		});

		// Expand error lines to match their code block's natural scroll width
		document.querySelectorAll<HTMLElement>('pre > code').forEach((code) => {
			const sw = code.scrollWidth;
			code.querySelectorAll<HTMLElement>('.twoslash-error-line').forEach((line) => {
				line.style.minWidth = `${sw}px`;
			});
		});

		// Portal non-persisted popups into a per-pre overflow:visible layer so they escape
		// overflow:clip without unclipping persisted popups or neighboring tokens.
		// Same code path for both standalone and compare pres.
		document.querySelectorAll<HTMLElement>('pre.twoslash').forEach((pre) => {
			const wrapper = document.createElement('div');
			wrapper.style.cssText = 'position:relative;';
			pre.parentNode!.insertBefore(wrapper, pre);
			wrapper.appendChild(pre);

			const portal = document.createElement('div');
			portal.style.cssText = 'position:absolute;inset:0;overflow:visible;pointer-events:none;';
			const portalCtx = document.createElement('div');
			portalCtx.className = 'twoslash';
			portalCtx.style.position = 'relative';
			portal.appendChild(portalCtx);
			wrapper.appendChild(portal);

			const code = pre.querySelector<HTMLElement>('code');

			pre.querySelectorAll<HTMLElement>('.twoslash-hover:not(.twoslash-query-persisted)').forEach((hover) => {
				const popup = hover.querySelector<HTMLElement>('.twoslash-popup-container');
				if (!popup) return;
				let origParent: Element | null = null;
				let origNextSibling: ChildNode | null = null;
				let scrollHandler: (() => void) | null = null;
				let restoreTimer: ReturnType<typeof setTimeout> | null = null;

				function portalize() {
					if (restoreTimer) { clearTimeout(restoreTimer); restoreTimer = null; }
					if (popup.parentElement === portalCtx) return;
					origParent = popup.parentElement;
					origNextSibling = popup.nextSibling;
					const popupRect = popup.getBoundingClientRect();
					const wrapperRect = wrapper.getBoundingClientRect();
					const top = popupRect.top - wrapperRect.top;
					const left = popupRect.left - wrapperRect.left;
					popup.style.position = 'absolute';
					popup.style.top = top + 'px';
					popup.style.left = left + 'px';
					popup.style.transform = 'none';
					popup.style.translate = 'none';
					popup.style.opacity = '1';
					popup.style.pointerEvents = 'auto';
					portalCtx.appendChild(popup);
					if (code) {
						const initialScrollLeft = code.scrollLeft;
						const initialLeft = left;
						scrollHandler = () => {
							popup.style.left = (initialLeft - (code.scrollLeft - initialScrollLeft)) + 'px';
						};
						code.addEventListener('scroll', scrollHandler, { passive: true });
					}
				}

				function restore() {
					restoreTimer = null;
					if (scrollHandler && code) { code.removeEventListener('scroll', scrollHandler); scrollHandler = null; }
					if (origParent) {
						origParent.insertBefore(popup, origNextSibling);
						origParent = null; origNextSibling = null;
					}
					popup.style.position = '';
					popup.style.top = '';
					popup.style.left = '';
					popup.style.transform = '';
					popup.style.translate = '';
					popup.style.opacity = '';
					popup.style.pointerEvents = '';
				}

				hover.addEventListener('mouseenter', portalize);
				hover.addEventListener('mouseleave', () => { restoreTimer = setTimeout(restore, 120); });
				popup.addEventListener('mouseenter', () => { if (restoreTimer) { clearTimeout(restoreTimer); restoreTimer = null; } });
				popup.addEventListener('mouseleave', restore);
			});
		});

		// Keep popups synced with horizontal scroll: when code scrolls, translate popups by the same amount
		document.querySelectorAll<HTMLElement>('pre').forEach((pre) => {
			if (pre.closest('.twoslash-popup-container')) return;
			const code = pre.querySelector('code');
			if (!code) return;
			code.addEventListener('scroll', () => {
				pre.style.setProperty('--code-scroll-x', `${code.scrollLeft}px`);
			}, { passive: true });
		});
	</script>
	<style>
		:global(.copy-btn) {
			position: absolute;
			top: 0.5em;
			right: 0.5em;
			padding: 0.35em;
			background: rgba(255, 255, 255, 0.08);
			color: #aaa;
			border: 1px solid rgba(255, 255, 255, 0.15);
			border-radius: 5px;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			transition: background 0.15s, color 0.15s;
		}
		:global(.copy-btn:hover) {
			background: rgba(255, 255, 255, 0.2);
			color: #fff;
		}
		:global(.copy-btn--small) {
			padding: 0.2em;
			border-radius: 3px;
		}
		:global(.copy-btn--small svg) {
			width: 12px;
			height: 12px;
		}
	</style>
	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						{pubDate && (
							<div class="date">
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)}
							</div>
						)}
						<h1>{title}</h1>
						{subtitle && <p class="subtitle">{subtitle}</p>}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
