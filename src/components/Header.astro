---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import SocialLinks from './SocialLinks.astro';
---

<script>
	const root = document.documentElement;
	if (localStorage.getItem('theme') === 'dark') root.classList.add('dark');

	document.getElementById('theme-toggle')?.addEventListener('click', () => {
		const dark = root.classList.toggle('dark');
		localStorage.setItem('theme', dark ? 'dark' : 'light');
	});
</script>

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">About Me</HeaderLink>
			<HeaderLink href="/resume">Resume</HeaderLink>
			<HeaderLink href="/tech">Tech</HeaderLink>
			<HeaderLink href="/depth">DEPTH</HeaderLink>
		</div>
		<div class="social-links">
			<button id="theme-toggle" aria-label="Toggle dark mode">
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
			</button>
			<SocialLinks />
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--header-bg);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}
	#theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 1em 0.5em;
		color: rgb(var(--black));
		display: flex;
		align-items: center;
	}
	#theme-toggle:hover {
		color: var(--accent);
	}
	/* show sun in dark mode, moon in light mode */
	.icon-moon { display: block; }
	.icon-sun  { display: none; }
	:global(.dark) .icon-moon { display: none; }
	:global(.dark) .icon-sun  { display: block; }
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
